# 환경 변수 템플릿 — 이 파일을 복사해 '.env.local' 을 만들고 값을 기입하세요.
#
# ── 저장소 선택 ──────────────────────────────────────────────
# 아래 SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY 가 모두 채워져 있으면 Supabase 를 사용하고,
# 비어 있으면 자동으로 구글 시트(없으면 로컬 JSON)로 폴백합니다. (lib/store.ts)
#
# [권장] Supabase (학생 수가 많아질 때: 빠른 단일행 저장, 행 상한/할당량 문제 없음)
#   supabase.com 에서 프로젝트 생성 → Settings > API 에서 아래 값 복사
#   Project URL → SUPABASE_URL,  service_role key → SUPABASE_SERVICE_ROLE_KEY
#   최초 1회: supabase/schema.sql 실행 후 `node scripts/migrate-to-supabase.mjs`
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── (선택) 출결 알림 문자 — 알리고(Aligo) ──
# 미설정이면 출결은 정상 동작하고 문자만 발송되지 않음.
# 발신번호(ALIGO_SENDER)는 통신사/알리고에 사전등록(법적 필수)해야 발송됩니다.
ALIGO_API_KEY=your-aligo-api-key
ALIGO_USER_ID=your-aligo-user-id
ALIGO_SENDER=0212345678
# (카카오 알림톡 사용 시) 채널 senderkey + 승인된 템플릿 코드. 없으면 일반 SMS로 발송.
ALIGO_KAKAO_SENDERKEY=
ALIGO_KAKAO_TPL_CODE=
# 테스트(실제 발송 안 함): Y / 실발송: N
ALIGO_TEST_MODE=N

# ── (선택) 출결 QR 서명 비밀키 (미설정 시 개발용 기본값 사용 — 운영에선 꼭 설정) ──
ATTEND_TOKEN_SECRET=change-me-to-a-long-random-string

# ── (선택) 구글 스프레드시트 — Supabase 미설정 시 폴백/미러용 ──

# 1. Google Cloud 서비스 계정 이메일
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# 2. Google Cloud 서비스 계정 Private Key (줄바꿈 \n을 포함한 전체 문자열)
# 주의: 따옴표 없이 그대로 복사하거나 필요 시 따옴표로 감싸서 작성해 주세요.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQC...\n-----END PRIVATE KEY-----\n"

# 3. 연동할 구글 스프레드시트 ID
# (스프레드시트 URL인 https://docs.google.com/spreadsheets/d/[시트ID]/edit#gid=0 에서 대괄호 영역의 ID 값)
GOOGLE_SHEET_ID=your-google-sheet-id-here
